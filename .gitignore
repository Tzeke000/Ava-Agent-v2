__pycache__/
*.pyc
*.pyo

state/*.tmp
state/**/*.tmp
memory/**/*.tmp

chatlog.jsonl

memory/
state/
profiles/
ava_mood.json
chatlog.jsonl

apps/ava-control/src-tauri/target/
apps/ava-control/node_modules/
apps/ava-control/dist/

state/camera/
state/face_model.yml
tmp_chat.json

# Biometric data — face encodings + onboarding photos. Privacy-sensitive.
faces/

# Local Claude Code settings (per-machine config / permission allowlists)
.claude/

# Wake-word custom models — large ONNX, generated locally per machine.
models/wake_words/*.onnx

# Audio harness external models — large binaries, downloaded separately.
# Piper voice models: https://huggingface.co/rhasspy/piper-voices  (~50-100MB each)
# faster-whisper models live in ~/.cache/huggingface/hub/, also not committed.
models/piper/
# (also excludes en_US-lessac-high.onnx which is 108MB)

# Curriculum raw downloads — regeneratable from Project Gutenberg via
# scripts/_parse_aesop.py. The split per-fable files are committed; the
# raw multi-MB source isn't.
curriculum/foundation/_raw_*.txt

# Diagnostic / regression scratch logs — generated by debugging runs,
# not intended to be committed.
trace_verify_*.log
regression_test.log
*_verify.log
ava_*.log
discord_debug.log

# Doctor / autonomous testing — session logs may contain transcripts.
# Per-machine, not for source control.
logs/

# Graphify code-graph output. Generated by `graphify update <repo>`. Mirrored
# into D:\ClaudeCodeMemory\graphify\ava-agent-v2\ for Claude Code's query path.
# Cache subdir is reused for incremental updates — keep local, don't commit.
graphify-out/
