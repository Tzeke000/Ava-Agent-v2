{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ava",
  "version": "0.1.0",
  "identifier": "com.ava.control",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ava",
        "width": 1320,
        "height": 880,
        "resizable": true
      },
      {
        "label": "widget",
        "title": "Ava Widget",
        "url": "/?widget=1",
        "width": 150,
        "height": 150,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
